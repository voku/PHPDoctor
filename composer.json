{
    "name": "voku/phpdoctor",
    "description": "Type and PHPDoc quality profiling for PHP projects.",
    "type": "library",
    "keywords": [
        "php",
        "phpdoc",
        "types",
        "quality",
        "baseline"
    ],
    "homepage": "https://github.com/voku/PHPDoctor",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Lars Moelleken",
            "homepage": "https://www.moelleken.org/"
        }
    ],
    "require": {
        "php": ">=8.1",
        "voku/simple-php-code-parser": "~0.21.0",
        "symfony/console": "~3.4 || ~4.1 || ~5.0 || ~6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.33",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "voku\\": "src/voku/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "voku\\tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "bin/phpdoctor"
    ]
}
